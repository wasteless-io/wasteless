# Copy to .env and fill in. Same variables for ui/.env.

# --- PostgreSQL (docker-compose defaults) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wasteless
DB_USER=wasteless
DB_PASSWORD=changeme

# --- AWS ---
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=

# Recommended: cross-account AssumeRole (see docs/AWS_SETUP.md).
# Deploy onboarding/cloudformation or onboarding/terraform in the target
# account, then paste the role ARNs from the stack/module outputs.
# Read-only role, used for all collection/detection:
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/wasteless-readonly
# Write role, only assumed for approved remediation actions.
# If AWS_ROLE_ARN is set without this, write actions fail closed.
# AWS_WRITE_ROLE_ARN=arn:aws:iam::123456789012:role/wasteless-remediation
# Only if the roles were created with an ExternalId condition:
# AWS_EXTERNAL_ID=
# AWS_ROLE_SESSION_NAME=wasteless

# Legacy: static credentials via ~/.aws or environment (used as-is when
# AWS_ROLE_ARN is unset; also the source credentials for AssumeRole):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- AI insights (optional) ---
# Any litellm model id works; wasteless runs fine with this unset
# (recommendations simply have no AI explanation).
# Requires: pip install litellm
# WASTELESS_LLM_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...
# ... or any other provider litellm supports:
# WASTELESS_LLM_MODEL=ollama/llama3
# WASTELESS_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# Fixed rate used to display LLM costs (tracked in USD by litellm) in EUR,
# same convention as the detectors' AWS pricing.
# USD_TO_EUR=0.92

# --- Email notifications (optional, V1) ---
# Sends an email when a remediation action fails, if notifications.email
# and notifications.notify_on_error are set in config/remediation.yaml
# (Settings page). SMTP credentials live here, never in the versionable
# policy YAML. Unset SMTP_HOST = notifications silently disabled.
# notifications.slack_webhook is accepted by policy import/export for
# forward compatibility but nothing sends to it yet.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=wasteless@example.com
# SMTP_USE_TLS=true
